/* USER CODE BEGIN 4 */

void DetectPhaseType()
{
	switch(chargerState)
	{
	case ChargeLow:
		if(savedLBtype != Tp)
		{
			chargerState = ChargeOngoing;
			return;
		}

		char msgl[]="L\n";
		HAL_UART_Transmit(&huart2,(uint8_t*)msgl,strlen(msgl),HAL_MAX_DELAY);

		sum1=sum1+RxCurrents.I1rms;
		sum2=sum2+RxCurrents.I2rms;
		sum3=sum3+RxCurrents.I3rms;
		samples++;

		if(samples>=SAMPLE_COUNT)
		{
			CurrentAvrgBefore.I1rms= sum1/SAMPLE_COUNT;
			CurrentAvrgBefore.I2rms=sum2/SAMPLE_COUNT;
			CurrentAvrgBefore.I3rms=sum3/SAMPLE_COUNT;

			sum1=0;
			sum2=0;
			sum3=0;
			samples=0;
			chargerState = ChargeMiddle;


		}
		else
		{
			return;
		}

		break;

	case ChargeMiddle:
		char msgm[]="M\n";
		HAL_UART_Transmit(&huart2,(uint8_t*)msgm,strlen(msgm),HAL_MAX_DELAY);
		sum1=sum1+RxCurrents.I1rms;
		sum2=sum2+RxCurrents.I2rms;
		sum3=sum3+RxCurrents.I3rms;
		samples++;

		if(samples>=SAMPLE_COUNT)
		{
			CurrentAvrgAfter.I1rms= sum1/SAMPLE_COUNT;
			CurrentAvrgAfter.I2rms=sum2/SAMPLE_COUNT;
			CurrentAvrgAfter.I3rms=sum3/SAMPLE_COUNT;

			float diff1 = CurrentAvrgAfter.I1rms-CurrentAvrgBefore.I1rms;
			float diff2=  CurrentAvrgAfter.I2rms-CurrentAvrgBefore.I2rms;
			float diff3=  CurrentAvrgAfter.I3rms-CurrentAvrgBefore.I3rms;

			if (diff1 > threshold && diff2 > threshold && diff3 > threshold) {
				Phase =Tp;
			} else if (diff1 > threshold) {
				Phase =Sp1;
			} else if (diff2 > threshold) {
				Phase =Sp2;
			} else if (diff3 > threshold) {
				Phase =Sp3;
			}
			else {
				chargerState = ChargeLow;
			}

			sum1=0;
			sum2=0;
			sum3=0;
			samples=0;
			Calibrated =true;
			chargerState = ChargeOngoing;
		}
		else
		{
			return;
		}
		break;

	case ChargeOngoing:
		break;
	case LBUnDetected:
		if(Charge)
		{
			chargerState = (!Calibrated) ? ChargeLow : ChargeOngoing;
		}
		else
		{
			chargerState=IDLE;
		}

		break;
	case IDLE:
		break;

	}



}


