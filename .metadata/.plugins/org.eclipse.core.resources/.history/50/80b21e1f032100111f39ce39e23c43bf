/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_DMA_Init();
  MX_USART2_UART_Init();
  MX_SubGHz_Phy_Init();
  MX_RNG_Init();
  /* USER CODE BEGIN 2 */
  RadioInit();
  // remember to enable uart receiving enable in uart init function
  LoadSerialNumber();

  //hard coded 21-01-2026
  //Flash_Read_data(CONFIG_ADDR, LBtype, 2);
  savedLBtype = Sp1;   // LBtype[0];
  //hard coded 21-01-2026
  HAL_Delay(100);


  Send_Request();


  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {

	  uint32_t timeNow =HAL_GetTick();

	  switch(LoRaState)
	  {

	  case STATE_TX_DONE:
		  LoRaState = STATE_IDLE;
		  if(CalibLB) Radio.Rx(20000);
		  else Radio.Rx(RX_TIMOUT);
		  break;


	  case STATE_RX_DONE:
		  LoRaState = STATE_IDLE;
		  struct AES_ctx ctx;
		  AES_init_ctx_iv(&ctx, key, iv);
		  AES_CBC_decrypt_buffer(&ctx, (uint8_t*)LoRaCH_Rx, CH_RX_SIZE);
		  sscanf((char*)LoRaCH_Rx, "%10[^:]:%f:%f:%f", (char*)RNR, &RxCurrents.I1rms, &RxCurrents.I2rms, &RxCurrents.I3rms);


		    recievedRN =(uint32_t)atol((char*)RNR);
		    if( strcmp((char*)RNR ,(char*)SN) ==0 )
		    {
		    	// compleate SN write
		    	char msgl[]="S\n";
		        HAL_UART_Transmit(&huart2,(uint8_t*)msgl,strlen(msgl),HAL_MAX_DELAY);
		        WriteSN = false;

		        /*new frequency update */
		        if(Flash_Erase_Page(FREQ_CONFIG_ADDR) == HAL_OK)
				{

		        	Frequency_Done[0]  = 1;
					Flash_Write_data(FREQ_CONFIG_ADDR,Frequency_Done,1);

					uint16_t received_freq = 0;
					sscanf((char*)&RNR[3] , "%3hu" , &received_freq);
					Frequency_flash[0] = received_freq ;

//					HAL_NVIC_SystemReset();

				}
		        /*----------------------*/


		        Send_Request();

		    }

		    else if(RNR[0]==5 && RNR[1]==5 && RNR[2]==5  && CalibLB)
		    {
		    	// calibration Done
		    	CalibLB = false;
		    	Send_Request();

		    	char uartConfig_buf[64];
		    	snprintf(uartConfig_buf, sizeof(uartConfig_buf), "CBR:%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d\n",
		    	         RNR[0], RNR[1], RNR[2], RNR[3]-'0', RNR[4]-'0', RNR[5]-'0',
		    	         RNR[6]-'0', RNR[7]-'0', RNR[8]-'0', RNR[9]-'0', RNR[10]-'0');

		    	LBtype[0] = (uint64_t)(RNR[3]-'0');

		    	HAL_UART_Transmit(&huart2, (uint8_t*)uartConfig_buf, strlen( uartConfig_buf), HAL_MAX_DELAY);

		    	//save calibrated data on flash

		    	if(Flash_Erase_Page(CONFIG_ADDR)==HAL_OK)
		    	{
		    		Flash_Write_data(CONFIG_ADDR,LBtype,2);
                    HAL_NVIC_SystemReset();
		    	}

		    }

		    else if(recievedRN==randNum)
			{
				//its a valid packet
		    	 i1 = (int)(RxCurrents.I1rms + 0.5);
				 i2 = (int)(RxCurrents.I2rms + 0.5);
				 i3 = (int)(RxCurrents.I3rms + 0.5);

				DetectPhaseType();

			if(chargerState==ChargeOngoing  || chargerState==IDLE){

                switch(savedLBtype)
                {
                case Sp1:
                	CC = i1;
					sprintf(txToSom,"%d\n",CC);
					HAL_UART_Transmit(&huart2,(uint8_t*)txToSom,strlen(txToSom),HAL_MAX_DELAY);
                	break;
                case Sp2:
                	CC = i2;
					sprintf(txToSom,"%d\n",CC);
					HAL_UART_Transmit(&huart2,(uint8_t*)txToSom,strlen(txToSom),HAL_MAX_DELAY);
                	break;
                case Sp3:
                	CC = i3;
					sprintf(txToSom,"%d\n",CC);
					HAL_UART_Transmit(&huart2,(uint8_t*)txToSom,strlen(txToSom),HAL_MAX_DELAY);
                	break;
                case Tp:
					switch(Phase)
					{
					case Sp1:
						CC = i1;
						sprintf(txToSom,"%d\n",CC);
						HAL_UART_Transmit(&huart2,(uint8_t*)txToSom,strlen(txToSom),HAL_MAX_DELAY);
						break;
					case Sp2:
						CC = i2;
						sprintf(txToSom,"%d\n",CC);
						HAL_UART_Transmit(&huart2,(uint8_t*)txToSom,strlen(txToSom),HAL_MAX_DELAY);
						break;
					case Sp3:
						CC = i3;
						sprintf(txToSom,"%d\n",CC);
						HAL_UART_Transmit(&huart2,(uint8_t*)txToSom,strlen(txToSom),HAL_MAX_DELAY);
						break;
					case Tp:
						CC=(i1 > i2 ? (i1 > i3 ? i1 : i3) : (i2 > i3 ? i2 : i3));
						sprintf(txToSom,"%d\n",CC);
						HAL_UART_Transmit(&huart2,(uint8_t*)txToSom,strlen(txToSom),HAL_MAX_DELAY);
						break;
					case NotApper:
						break;
					}
                	break;
                case NotApper:
                	break;
                }

			}

				timer=timeNow; // reset timer
				HAL_Delay(Radio.GetWakeupTime()+100);
				Send_Request();
				//HAL_GPIO_TogglePin(GPIOB, GPIO_PIN_5);


			}
			else
			{
				//not a valid packet , dont accept current values
				HAL_Delay(Radio.GetWakeupTime()+100);
				Send_Request();
			}

			break;

	  case STATE_RX_TIMEOUT:
		  LoRaState = STATE_IDLE;
		   Send_Request();
		   break;

	  case STATE_RX_ERROR:
		  break;

	  case STATE_TX_TIMEOUT:
		  break;

	  case STATE_IDLE:

		  break;
	  }

	  if(timeNow-timer>WATCHDOG_TIMEOUT)
	  {
		  // consumed current unknown
		  ucount++; // not  a good practice
		  if(ucount>=1000000)
		  {
			  ucount=0;
			  chargerState = LBUnDetected;
			  char msgu[]="U\n";
			  HAL_UART_Transmit(&huart2,(uint8_t*)msgu,strlen(msgu),HAL_MAX_DELAY);
		  }

		  // some delay but

	  }

    /* USER CODE END WHILE */
//    MX_SubGHz_Phy_Process();

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

